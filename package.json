{
    "name": "sv5ui",
    "version": "2.0.0",
    "description": "A modern Svelte 5 UI component library with Tailwind CSS",
    "author": "ndlabdev",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ndlabdev/sv5ui.git"
    },
    "homepage": "https://sv5ui.vercel.app",
    "bugs": {
        "url": "https://github.com/ndlabdev/sv5ui/issues"
    },
    "scripts": {
        "dev": "vite dev",
        "build": "vite build && npm run prepack",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "prepack": "svelte-kit sync && svelte-package && publint",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "prettier --check . && eslint .",
        "format": "prettier --write .",
        "test:unit": "vitest",
        "test": "npm run test:unit -- --run"
    },
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./editor": {
            "types": "./dist/Editor/index.d.ts",
            "svelte": "./dist/Editor/index.js",
            "default": "./dist/Editor/index.js"
        },
        "./theme.css": {
            "import": "./dist/theme.css",
            "default": "./dist/theme.css"
        }
    },
    "peerDependencies": {
